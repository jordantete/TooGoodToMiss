# Copy to .env (never committed).

# --- Runtime ---
USER_EMAIL=your.email@example.com
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=123456789

# --- Initial seed for the TGTG session ---
# WARNING: these values are used ONLY WHEN state.json IS CREATED.
# Editing them here and redeploying has NO effect for as long as
# state.json exists on the VPS. To force new tokens:
#     ssh $VPS_USER@$VPS_HOST "rm $VPS_BOT_PATH/state.json"
ACCESS_TOKEN=
REFRESH_TOKEN=
TGTG_COOKIE=
LAST_TIME_TOKEN_REFRESHED=
USER_LANGUAGE=fr

# --- Deployment (read by scripts/deploy.sh) ---
VPS_USER=root
VPS_HOST=203.0.113.10
VPS_BOT_PATH=/root/toogoodtomiss
SSH_KEY=~/.ssh/id_ed25519
